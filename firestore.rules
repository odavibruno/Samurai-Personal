rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin (Mestre)
    function isMestre() {
      return request.auth.token.email == 'w.samurai.fitness@gmail.com'; // Ou use custom claims
    }

    // Helper to check if user is accessing their own data
    function isOwner(userId) {
      return request.auth != null && request.auth.token.email == userId;
    }

    // Coleção de Usuários
    match /users/{userId} {
      // O Mestre pode ler e escrever em qualquer usuário
      allow read, write: if isMestre();
      
      // O próprio usuário pode ler e escrever seu perfil
      allow read, write: if isOwner(userId);

      // Subcoleções (workouts, history, messages)
      match /workouts/{document=**} {
        allow read, write: if isMestre() || isOwner(userId);
      }
      
      match /history/{document=**} {
        allow read, write: if isMestre() || isOwner(userId);
      }
      
      match /messages/{document=**} {
        allow read, write: if isMestre() || isOwner(userId);
      }
    }

    // Coleção de Sessões Ativas (active_sessions)
    match /active_sessions/{userId} {
      allow read, write: if isMestre() || isOwner(userId);
    }
  }
}
